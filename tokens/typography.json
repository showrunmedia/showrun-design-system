{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "font": {
    "family": {
      "display": {
        "$value": "Albert Sans",
        "$type": "fontFamily",
        "$description": "Display and headings. Variable font, 100-800 + true italics. Self-hosted as WOFF2. Source: Google Fonts.",
        "$extensions": {
          "showrun.candidate": "v0.1",
          "showrun.locked-march-2026": true,
          "showrun.fallback-stack": "'Albert Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
          "showrun.weights": [600, 700, 800],
          "showrun.italic-supported": true
        }
      },
      "body": {
        "$value": "Plus Jakarta Sans",
        "$type": "fontFamily",
        "$description": "Body and reading. Variable font, 200-800 + true italics. Self-hosted as WOFF2. Source: Google Fonts.",
        "$extensions": {
          "showrun.candidate": "v0.1",
          "showrun.locked-march-2026": true,
          "showrun.fallback-stack": "'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
          "showrun.weights": [400, 500, 600, 800],
          "showrun.italic-supported": true
        }
      },
      "script": {
        "$value": "Sedgwick Ave",
        "$type": "fontFamily",
        "$description": "Script / warmth font. SINGLE WEIGHT (400). Use sparingly: sign-offs, pull quotes, BTS captions, personal closing lines, social quote cards ONLY. NEVER body, headings, table headers, badges, buttons.",
        "$extensions": {
          "showrun.candidate": "v0.1",
          "showrun.locked-march-2026": true,
          "showrun.usage-restriction": "spice-not-staple",
          "showrun.weights": [400]
        }
      }
    },
    "weight": {
      "regular":   { "$value": "400", "$type": "fontWeight", "$description": "Regular — body default" },
      "medium":    { "$value": "500", "$type": "fontWeight", "$description": "Medium — micro text emphasis" },
      "semibold":  { "$value": "600", "$type": "fontWeight", "$description": "SemiBold — body emphasis, H4" },
      "bold":      { "$value": "700", "$type": "fontWeight", "$description": "Bold — H2, H3" },
      "extrabold": { "$value": "800", "$type": "fontWeight", "$description": "ExtraBold — Display, H1" }
    },
    "size": {
      "screen": {
        "display": { "$value": "56px", "$type": "dimension", "$description": "Display screen — hero slides, brand mark" },
        "h1":      { "$value": "44px", "$type": "dimension", "$description": "H1 screen — document titles, deck covers" },
        "h2":      { "$value": "32px", "$type": "dimension", "$description": "H2 screen — section headers" },
        "h3":      { "$value": "22px", "$type": "dimension", "$description": "H3 screen — subsection headers" },
        "h4":      { "$value": "18px", "$type": "dimension", "$description": "H4 screen — sub-subsection, callouts" },
        "body":    { "$value": "14px", "$type": "dimension", "$description": "Body screen — paragraphs" },
        "body-sm": { "$value": "13px", "$type": "dimension", "$description": "Body small screen" },
        "small":   { "$value": "12px", "$type": "dimension", "$description": "Small screen — captions, metadata" },
        "micro":   { "$value": "10px", "$type": "dimension", "$description": "Micro screen — footers, fine print" }
      },
      "print": {
        "display": { "$value": "42pt", "$type": "dimension", "$description": "Display print — cover pages" },
        "h1":      { "$value": "28pt", "$type": "dimension", "$description": "H1 print — document titles" },
        "h2":      { "$value": "18pt", "$type": "dimension", "$description": "H2 print — section headers" },
        "h3":      { "$value": "14pt", "$type": "dimension", "$description": "H3 print — subsection headers" },
        "h4":      { "$value": "12pt", "$type": "dimension", "$description": "H4 print — callouts" },
        "body":    { "$value": "11pt", "$type": "dimension", "$description": "Body print — paragraphs" },
        "small":   { "$value": "9pt",  "$type": "dimension", "$description": "Small print — captions" },
        "micro":   { "$value": "8pt",  "$type": "dimension", "$description": "Micro print — footers" }
      }
    },
    "lineHeight": {
      "tight":    { "$value": "1.1", "$type": "number", "$description": "Tight — large display type" },
      "snug":     { "$value": "1.25","$type": "number", "$description": "Snug — H1/H2 headings" },
      "normal":   { "$value": "1.5", "$type": "number", "$description": "Normal — small text, captions" },
      "relaxed":  { "$value": "1.6", "$type": "number", "$description": "Relaxed — body text default" },
      "loose":    { "$value": "1.75","$type": "number", "$description": "Loose — long-form reading" }
    },
    "letterSpacing": {
      "caps-normal": { "$value": "0.05em", "$type": "dimension", "$description": "Required for UPPERCASE — minimum 0.5px / max ~2px at large display" },
      "caps-wide":   { "$value": "0.1em",  "$type": "dimension", "$description": "Wider tracking for Labels and small caps" },
      "dark-bg-adjust": { "$value": "0.02em", "$type": "dimension", "$description": "Dark-bg adjustment — add to body letter-spacing when on Midnight/Dark backgrounds" }
    },
    "case": {
      "display": { "$value": "uppercase", "$type": "string", "$description": "Display, H1, H2, Labels — ALL CAPS" },
      "h3":      { "$value": "none",      "$type": "string", "$description": "H3 — Title Case" },
      "h4":      { "$value": "none",      "$type": "string", "$description": "H4 — Title Case" },
      "body":    { "$value": "none",      "$type": "string", "$description": "Body — sentence case" }
    }
  }
}
